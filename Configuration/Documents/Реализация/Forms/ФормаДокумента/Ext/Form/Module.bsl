&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    УстановитьВидимость();
    УстановитьОтборДоговора();
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
КонецПроцедуры

#Область ОбработчикиСобытийЭлементовФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
    ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
    ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
    ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
    Объект.Договор = Неопределено;
    КонтрагентПриИзмененииНаСервере();
КонецПроцедуры

// ТЧ Товары
&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
    ПересчитатьСтрокуТовары();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыЦенаПриИзменении(Элемент)
    ПересчитатьСтрокуТовары();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыНоменклатураПередНачаломВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
    МассивТипов = Новый Массив;
    МассивТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Товар"));
    МассивТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Материал"));
    ДанныеВыбора.Параметры.УстановитьЗначениеПараметра("ТипНоменклатуры", МассивТипов);
КонецПроцедуры

&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
    Строка = Элементы.Товары.ТекущиеДанные;
    Если Строка = Неопределено Тогда
        Возврат;
    КонецЕсли;
    Строка.Цена = ПолучитьЦену(Строка.Номенклатура, Объект.Дата);
    ПересчитатьСтрокуТовары();
КонецПроцедуры

// ТЧ Услуги
&НаКлиенте
Процедура УслугиКоличествоПриИзменении(Элемент)
    ПересчитатьСтрокуУслуги();
КонецПроцедуры

&НаКлиенте
Процедура УслугиЦенаПриИзменении(Элемент)
    ПересчитатьСтрокуУслуги();
КонецПроцедуры

&НаКлиенте
Процедура УслугиУслугаПередНачаломВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
    ДанныеВыбора.Параметры.УстановитьЗначениеПараметра("ТипНоменклатуры",
        ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"));
КонецПроцедуры

&НаКлиенте
Процедура УслугиУслугаПриИзменении(Элемент)
    Строка = Элементы.Услуги.ТекущиеДанные;
    Если Строка = Неопределено Тогда
        Возврат;
    КонецЕсли;
    Строка.Цена = ПолучитьЦену(Строка.Услуга, Объект.Дата);
    ПересчитатьСтрокуУслуги();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПересчитатьСтрокуТовары()
    Строка = Элементы.Товары.ТекущиеДанные;
    Если Строка = Неопределено Тогда
        Возврат;
    КонецЕсли;
    Строка.Сумма = Строка.Количество * Строка.Цена;
    ПересчитатьСуммуДокумента();
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСтрокуУслуги()
    Строка = Элементы.Услуги.ТекущиеДанные;
    Если Строка = Неопределено Тогда
        Возврат;
    КонецЕсли;
    Строка.Сумма = Строка.Количество * Строка.Цена;
    ПересчитатьСуммуДокумента();
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСуммуДокумента()
    Объект.СуммаДокумента = 0;
    Для Каждого Строка Из Объект.Товары Цикл
        Объект.СуммаДокумента = Объект.СуммаДокумента + Строка.Сумма;
    КонецЦикла;
    Для Каждого Строка Из Объект.Услуги Цикл
        Объект.СуммаДокумента = Объект.СуммаДокумента + Строка.Сумма;
    КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура КонтрагентПриИзмененииНаСервере()
    УстановитьВидимость();
    УстановитьОтборДоговора();
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимость()
    ТипКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
        Объект.Контрагент, "ТипКонтрагента");
    Элементы.Договор.Видимость =
        ТипКонтрагента = Перечисления.ТипыКонтрагентов.Покупатель;
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборДоговора()
    МассивПараметров = Новый Массив;
    МассивПараметров.Добавить(Новый ПараметрВыбора("Владелец", Объект.Контрагент));
    Элементы.Договор.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьЦену(Номенклатура, Дата)
    Отбор = Новый Структура("Номенклатура, ВидЦены", Номенклатура,
        Перечисления.ВидыЦенПродажи.Розничная);
    Структура = РегистрыСведений.ЦеныНоменклатуры.ПолучитьПоследнее(Дата, Отбор);
    Возврат Структура.Цена;
КонецФункции

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
    ПодключаемыеКомандыКлиент.НачатьВыполнениеКоманды(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПродолжитьВыполнениеКомандыНаСервере(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт
    ВыполнитьКомандуНаСервере(ПараметрыВыполнения);
КонецПроцедуры

&НаСервере
Процедура ВыполнитьКомандуНаСервере(ПараметрыВыполнения)
    ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, ПараметрыВыполнения, Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
    ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры

#КонецОбласти