&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    УстановитьОтборКлиента();
КонецПроцедуры


#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура УслугиУслугаПриИзменении(Элемент)
    Строка = Элементы.Услуги.ТекущиеДанные;
    Если Строка = Неопределено Тогда
        Возврат;
    КонецЕсли;
    Строка.Цена = ПолучитьЦену(Строка.Услуга, Объект.ДатаЗаписи);
    ПересчитатьСтрокуУслуги();
    ПересчитатьДатуОкончания();
КонецПроцедуры

&НаКлиенте
Процедура УслугиКоличествоПриИзменении(Элемент)
    ПересчитатьСтрокуУслуги();
    ПересчитатьДатуОкончания();
КонецПроцедуры

&НаКлиенте
Процедура УслугиЦенаПриИзменении(Элемент)
    ПересчитатьСтрокуУслуги();
КонецПроцедуры

&НаКлиенте
Процедура ДатаЗаписиПриИзменении(Элемент)
    ПересчитатьДатуОкончания();
КонецПроцедуры

&НаКлиенте
Процедура УслугиУслугаПередНачаломВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
    ДанныеВыбора.Параметры.УстановитьЗначениеПараметра("ТипНоменклатуры",
        ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"));
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПересчитатьСтрокуУслуги()
    Строка = Элементы.Услуги.ТекущиеДанные;
    Если Строка = Неопределено Тогда
        Возврат;
    КонецЕсли;
    Строка.Сумма = Строка.Количество * Строка.Цена;
    ПересчитатьСуммуДокумента();
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСуммуДокумента()
    Объект.СуммаДокумента = 0;
    Для Каждого Строка Из Объект.Услуги Цикл
        Объект.СуммаДокумента = Объект.СуммаДокумента + Строка.Сумма;
    КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьДатуОкончания()
    Если НЕ ЗначениеЗаполнено(Объект.ДатаЗаписи) Тогда
        Возврат;
    КонецЕсли;
    МассивУслуг = Новый Массив;
    Для Каждого Строка Из Объект.Услуги Цикл
        МассивУслуг.Добавить(Новый Структура("Услуга, Количество", Строка.Услуга, Строка.Количество));
    КонецЦикла;
    ОбщаяДлительность = ПолучитьОбщуюДлительность(МассивУслуг);
    Объект.ДатаОкончанияЗаписи = Объект.ДатаЗаписи + ОбщаяДлительность * 60;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьОбщуюДлительность(МассивУслуг)
    Если НЕ ЗначениеЗаполнено(МассивУслуг) Тогда
        Возврат 0;
    КонецЕсли;
    СписокНоменклатуры = Новый Массив;
    Для Каждого Стр Из МассивУслуг Цикл
        СписокНоменклатуры.Добавить(Стр.Услуга);
    КонецЦикла;
    Длительности = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(СписокНоменклатуры, "ДлительностьУслуги");
    ОбщаяДлительность = 0;
    Для Каждого Стр Из МассивУслуг Цикл
        Длительность = Длительности.Получить(Стр.Услуга);
        Если Длительность = Неопределено Тогда
            Длительность = 0;
        КонецЕсли;
        ОбщаяДлительность = ОбщаяДлительность + Стр.Количество * Длительность;
    КонецЦикла;
    Возврат ОбщаяДлительность;
КонецФункции

&НаСервере
Процедура УстановитьОтборКлиента()
    МассивПараметров = Новый Массив;
    МассивПараметров.Добавить(Новый ПараметрВыбора("ТипКонтрагента",
        Перечисления.ТипыКонтрагентов.Клиент));
    Элементы.Клиент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьЦену(Номенклатура, Дата)
    Отбор = Новый Структура("Номенклатура, ВидЦены", Номенклатура,
        Перечисления.ВидыЦенПродажи.Розничная);
    Структура = РегистрыСведений.ЦеныНоменклатуры.ПолучитьПоследнее(Дата, Отбор);
    Возврат Структура.Цена;
КонецФункции

#КонецОбласти