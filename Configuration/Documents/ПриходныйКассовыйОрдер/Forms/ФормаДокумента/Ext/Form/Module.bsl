&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    УстановитьВидимость();
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимость()
    ВидОп = Объект.ВидОперации;
    ВозвратПодотчётника = ПредопределенноеЗначение(
        "Перечисление.ВидыОперацийПоступленияДенег.ВозвратОтПодотчетника");

        ДопТипы = Новый Массив;
    Если ВидОп = ВозвратПодотчётника Тогда
        ДопТипы.Добавить(Тип("СправочникСсылка.Сотрудники"));
    Иначе
        ДопТипы.Добавить(Тип("СправочникСсылка.Контрагенты"));
    КонецЕсли;
    Элементы.Плательщик.ОграничениеТипа = Новый ОписаниеТипов(ДопТипы);

    ПоказыватьДоговор = Истина;
    Если ВидОп = ВозвратПодотчётника Тогда
        ПоказыватьДоговор = Ложь;
    ИначеЕсли ЗначениеЗаполнено(Объект.Плательщик)
          И ТипЗнч(Объект.Плательщик) = Тип("СправочникСсылка.Контрагенты") Тогда
        ТипКонтр = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
            Объект.Плательщик, "ТипКонтрагента");
        Если ТипКонтр = Перечисления.ТипыКонтрагентов.Клиент Тогда
            ПоказыватьДоговор = Ложь;
        КонецЕсли;
    КонецЕсли;
    Элементы.Договор.Видимость = ПоказыватьДоговор;
КонецПроцедуры

&НаКлиенте
Асинх Процедура ВидОперацииПриИзменении(Элемент)
    НовыйВидОп     = Объект.ВидОперации;
    БылСотрудник   = (ТипЗнч(Объект.Плательщик) = Тип("СправочникСсылка.Сотрудники"));
    НуженСотрудник = (НовыйВидОп = ПредопределенноеЗначение(
        "Перечисление.ВидыОперацийПоступленияДенег.ВозвратОтПодотчетника"));

    Если ЗначениеЗаполнено(Объект.Плательщик) И (БылСотрудник <> НуженСотрудник) Тогда
        Обещание = ВопросАсинх(
            "Вид операции изменён. Очистить поля Плательщик и Договор?",
            РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);
        Ответ = Ждать Обещание;
        ВидОперацииОбновитьФорму(Ответ = КодВозвратаДиалога.Да);
    Иначе
        ВидОперацииОбновитьФорму(Ложь);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииЗавершениеОчистки(Результат, ДопПараметры) Экспорт
    ВидОперацииОбновитьФорму(Результат = КодВозвратаДиалога.Да);
КонецПроцедуры

&НаСервере
Процедура ВидОперацииОбновитьФорму(ОчиститьПлательщика)
    Если ОчиститьПлательщика Тогда
        Объект.Плательщик = Неопределено;
        Объект.Договор    = Справочники.Договоры.ПустаяСсылка();
    КонецЕсли;
    УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура ПлательщикПриИзменении(Элемент)
    ПлательщикПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПлательщикПриИзмененииНаСервере()
    Объект.Договор = Справочники.Договоры.ПустаяСсылка();
    УстановитьВидимость();
КонецПроцедуры