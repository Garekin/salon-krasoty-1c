&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    УстановитьВидимость();
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимость()
    ВидОп = Объект.ВидОперации;
    НуженСотрудник = (ВидОп = Перечисления.ВидыОперацийРасходаДенег.ВыдачаПодотчетнику)
                  Или (ВидОп = Перечисления.ВидыОперацийРасходаДенег.ВыдачаЗаработнойПлаты);

    ДопТипы = Новый Массив;
    Если НуженСотрудник Тогда
        ДопТипы.Добавить(Тип("СправочникСсылка.Сотрудники"));
    Иначе
        ДопТипы.Добавить(Тип("СправочникСсылка.Контрагенты"));
    КонецЕсли;
    Элементы.Получатель.ОграничениеТипа = Новый ОписаниеТипов(ДопТипы);

    ПоказыватьДоговор = Истина;
    Если НуженСотрудник Тогда
        ПоказыватьДоговор = Ложь;
    ИначеЕсли ЗначениеЗаполнено(Объект.Получатель)
          И ТипЗнч(Объект.Получатель) = Тип("СправочникСсылка.Контрагенты") Тогда
        ТипКонтр = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
            Объект.Получатель, "ТипКонтрагента");
        Если ТипКонтр = Перечисления.ТипыКонтрагентов.Клиент Тогда
            ПоказыватьДоговор = Ложь;
        КонецЕсли;
    КонецЕсли;
    Элементы.Договор.Видимость = ПоказыватьДоговор;
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
    ВидОперацииОбновитьФорму();
КонецПроцедуры

&НаСервере
Процедура ВидОперацииОбновитьФорму()
    ВидОп = Объект.ВидОперации;
    НуженСотрудник = (ВидОп = Перечисления.ВидыОперацийРасходаДенег.ВыдачаПодотчетнику)
                  Или (ВидОп = Перечисления.ВидыОперацийРасходаДенег.ВыдачаЗаработнойПлаты);
    БылСотрудник = (ТипЗнч(Объект.Получатель) = Тип("СправочникСсылка.Сотрудники"));

    Если ЗначениеЗаполнено(Объект.Получатель) И (БылСотрудник <> НуженСотрудник) Тогда
        Объект.Получатель = Неопределено;
        Объект.Договор    = Справочники.Договоры.ПустаяСсылка();
    КонецЕсли;
    УстановитьВидимость();
КонецПроцедуры

&НаКлиенте
Процедура ПолучательПриИзменении(Элемент)
    ПолучательПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПолучательПриИзмененииНаСервере()
    Объект.Договор = Справочники.Договоры.ПустаяСсылка();
    УстановитьВидимость();
КонецПроцедуры