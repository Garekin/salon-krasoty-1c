Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)

    Если НЕ ЗначениеЗаполнено(СчетБухгалтерскогоУчета) Тогда
        Возврат;
    КонецЕсли;

    Если ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Товар Тогда
        СчетДопустим = (СчетБухгалтерскогоУчета = ПланыСчетов.Хозрасчетный.Товары);
    ИначеЕсли ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Материал Тогда
        СчетДопустим = (СчетБухгалтерскогоУчета = ПланыСчетов.Хозрасчетный.Материалы);
    ИначеЕсли ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
        СчетДопустим = (СчетБухгалтерскогоУчета = ПланыСчетов.Хозрасчетный.РасходыНаПродажу
            ИЛИ СчетБухгалтерскогоУчета = ПланыСчетов.Хозрасчетный.ПрочиеДоходыИРасходы);
    Иначе
        СчетДопустим = Истина;
    КонецЕсли;

    Если НЕ СчетДопустим Тогда
        ОбщегоНазначения.СообщитьПользователю(
            СтрШаблон("Счет %1 недопустим для типа номенклатуры ""%2"".",
                СчетБухгалтерскогоУчета, ТипНоменклатуры),
            , "Объект.СчетБухгалтерскогоУчета", , Отказ);
    КонецЕсли;

КонецПроцедуры